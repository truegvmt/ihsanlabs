# Required environment variables for local development and Vercel deployment
# Run: cp .env.example .env  — then fill in all values before starting dev
# Vercel: add these in Project Settings → Environment Variables

# ── Supabase (required) ────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only (API routes, ETL scripts). NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection (optional — for migrations and scripts)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ── AI (required) ──────────────────────────────────────────────────────────────
# Anthropic — LLM for allocation, due-diligence, waqf-agent (Prompts A–E)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — embeddings only (text-embedding-3-small, 1536-dim)
OPENAI_API_KEY=sk-your-openai-key-here

# ── IATI ETL Pipeline (required for data ingestion) ───────────────────────────
# IATI Datastore API endpoint
IATI_DATASTORE_URL=https://api.iatistandard.org/datastore
# Restrict to specific publisher (optional — comment out for all publishers)
# IATI_PUBLISHER_ID=uk-gov-1
# Exchange rate normalization (openexchangerates.org free tier works)
IATI_API_KEY=your-iati-exchange-rate-key-here

# ── Payments (Stripe — required for donations) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# ── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
