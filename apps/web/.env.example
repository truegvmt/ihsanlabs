# Ihsan Labs — .env.example
# Copy this to .env.local and fill in your actual values
# DO NOT include real secrets in this file

# ── Supabase ──────────────────────────────────────────────────
# The URL of your Supabase project (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# The service_role key for server-side operations (from Project Settings > API)
# WARNING: NEVER expose this on the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The anon key for client-side operations (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_ANON_KEY=your-anon-key

# Direct connection string for Postgres (from Project Settings > Database)
# Format: postgresql://[user]:[password]@[host]:[port]/[db]
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ── OpenAI ──────────────────────────────────────────────────
# Required for text-embedding-3-small in some RAG flows
OPENAI_API_KEY=sk-proj-your-openai-key

# ── Environment ───────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
